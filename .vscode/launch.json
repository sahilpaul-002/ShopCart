{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Nodemon",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "nodemon",
            "program": "${workspaceFolder}/Backend/index.js",
            "envFile": "${workspaceFolder}/Backend/.env",
            "restart": true,
            // "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}